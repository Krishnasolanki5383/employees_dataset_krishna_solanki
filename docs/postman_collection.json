{
  "info": {
    "name": "Employee Management System API",
    "description": "Complete Postman collection for all Employee Management API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "token",    "value": "paste_your_jwt_token_here" }
  ],
  "item": [
    {
      "name": "🔧 CRUD",
      "item": [
        { "name": "GET All Employees",   "request": { "method": "GET",    "url": "{{base_url}}/employees",     "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "GET Employee By ID",  "request": { "method": "GET",    "url": "{{base_url}}/employees/:id", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "POST Create Employee","request": { "method": "POST",   "url": "{{base_url}}/employees",     "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Krishna Solanki\",\n  \"email\": \"krishna@example.com\",\n  \"primarySkill\": \"Node.js\",\n  \"experience\": 3\n}", "options": { "raw": { "language": "json" } } } } },
        { "name": "PUT Replace Employee","request": { "method": "PUT",    "url": "{{base_url}}/employees/:id", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "PATCH Update Employee","request":{ "method": "PATCH",  "url": "{{base_url}}/employees/:id", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "DELETE Employee",     "request": { "method": "DELETE", "url": "{{base_url}}/employees/:id", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } }
      ]
    },
    {
      "name": "📦 Bulk Operations",
      "item": [
        { "name": "POST Bulk Create", "request": { "method": "POST",   "url": "{{base_url}}/employees/bulk-create", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "PATCH Bulk Update","request": { "method": "PATCH",  "url": "{{base_url}}/employees/bulk-update", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "DELETE Bulk Delete","request":{ "method": "DELETE", "url": "{{base_url}}/employees/bulk-delete", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } }
      ]
    },
    {
      "name": "🔍 Filters",
      "item": [
        { "name": "By Name",            "request": { "method": "GET", "url": "{{base_url}}/employees/name/:name",               "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "By Primary Skill",   "request": { "method": "GET", "url": "{{base_url}}/employees/primary-skill/:skill",     "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "By Domain",          "request": { "method": "GET", "url": "{{base_url}}/employees/domain/:domain",           "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "By Country",         "request": { "method": "GET", "url": "{{base_url}}/employees/country/:country",         "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "Verified Employees", "request": { "method": "GET", "url": "{{base_url}}/employees/verified",                 "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } },
        { "name": "Top Experience",     "request": { "method": "GET", "url": "{{base_url}}/employees/top-experience",           "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] } } }
      ]
    }
  ]
}
